# Copy to `.env` at the repository root when not using Doppler. NEVER commit real values.
#
# This app reads os.environ only; it does not load `.env` automatically. Either:
#   - Point your IDE at `.env` (e.g. VS Code / Cursor env file), or
#   - Export vars in your shell before `uv run`, or
#   - Use a tool like direnv.
#
# JSON formats for lists/dicts: see docs/DOPPLER_ENV_KEYS.md

# -----------------------------------------------------------------------------
# Required — bot will not start without these
# -----------------------------------------------------------------------------
DISCORD_BOT_TOKEN=
GUILD_ID=
APPLICATION_ID=

# -----------------------------------------------------------------------------
# Environment (optional — affects dev vs prod detection for Crafty, logging hints)
# Use: development | dev | production | prod
# -----------------------------------------------------------------------------
ENVIRONMENT=development

# -----------------------------------------------------------------------------
# Optional — features that need Google Gemini / Say cog
# -----------------------------------------------------------------------------
GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# Crafty Controller (optional)
# -----------------------------------------------------------------------------
CRAFTY_BASE_URL=
CRAFTY_USERNAME=
CRAFTY_PASSWORD=

# -----------------------------------------------------------------------------
# JSON arrays of Discord snowflake IDs (integers in JSON, e.g. [123,456])
# -----------------------------------------------------------------------------
ADMIN_USER_IDS=[]
VOICE_CHANNEL_IDS=[]

# -----------------------------------------------------------------------------
# Channel / category IDs (integers as plain numbers)
# -----------------------------------------------------------------------------
CREATE_FIRETEAM_CHANNEL_ID=
WATCH_PARTY_CHANNEL_ID=
WATCH_PARTY_EVENT_ID=
LEAGUE_CHANNEL_ID=
BACKUP_CHANNEL_ID=
BOT_SPAM_ID=
AFK_CHANNEL_ID=
SEEN_CATEGORY_ID=
HIDDEN_CATEGORY_ID=
WATERBOARD_CATEGORY_ID=

# -----------------------------------------------------------------------------
# Emoji IDs (integers)
# -----------------------------------------------------------------------------
HEADS_EMOJI_ID=
TAILS_EMOJI_ID=

# -----------------------------------------------------------------------------
# Birthday feature (integers)
# -----------------------------------------------------------------------------
BIRTHDAY_ANNOUNCEMENT_CHANNEL_ID=
BIRTHDAY_REACTION_CHANNEL_ID=
BIRTHDAY_ROLE_ID=
BIRTHDAY_EMOJI_ID=
BIRTHDAY_CHANNEL_ID=

# -----------------------------------------------------------------------------
# External APIs (strings)
# -----------------------------------------------------------------------------
OMDB_API_KEY=
OMDB_API_URL=
BRAVE_SEARCH_API_KEY=

# -----------------------------------------------------------------------------
# JSON object — MTG mana symbol URLs or labels (see existing cogs_config examples)
# -----------------------------------------------------------------------------
MANA_SYMBOLS={}

# -----------------------------------------------------------------------------
# Say / webhook (strings + JSON object for avatar map)
# -----------------------------------------------------------------------------
WEBHOOK_URL=
CHARACTER_AVATARS={}
ZERONI_REACTION_EMOJI=
COMMUNITY_NOTES_REACTION_EMOJI=
