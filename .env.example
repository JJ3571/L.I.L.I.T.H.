# Discord Bot Environment Variables
# Copy this to .env.docker (gitignored) and fill in values from Doppler.
# For local dev without .env, run: doppler run -- docker compose up -d
#
# NOTE: These are documented here so you know what Doppler needs to provide.
# Do NOT commit actual secret values anywhere.

# --- Core Bot ---
DISCORD_BOT_TOKEN=
APPLICATION_ID=
GUILD_ID=

# --- Database ---
# If using a managed Postgres (Neon, Supabase, etc.), set the full connection string.
# If using the optional postgres container below, use: postgresql://postgres:postgres@postgres:5432/discord_bot
DATABASE_URL=postgresql://postgres:password@host:5432/discord_bot

# --- Lavalink (must match lavalink/application.yml server.password) ---
LAVALINK_URI=http://127.0.0.1:2333
LAVALINK_PASSWORD=youshallnotpass

# --- Local Music HTTP (loopback server for Lavalink) ---
MUSIC_LOCAL_HTTP_HOST=127.0.0.1
MUSIC_LOCAL_HTTP_PORT=8765

# --- Gemini ---
GEMINI_API_KEY=

# --- Crafty Controller ---
CRAFTY_BASE_URL=
CRAFTY_USERNAME=
CRAFTY_PASSWORD=

# --- Admin & Error Alerts ---
ADMIN_USER_IDS=[]  # JSON array of user IDs
ERROR_ALERT_USER_ID=0
ERROR_ALERT_CHANNEL_ID=0

# --- Channels ---
BOT_SPAM_ID=0
VOICE_CHANNEL_IDS=[]  # JSON array
CREATE_FIRETEAM_CHANNEL_ID=0
WATCH_PARTY_CHANNEL_ID=0
WATCH_PARTY_EVENT_ID=0
LEAGUE_CHANNEL_ID=0
BACKUP_CHANNEL_ID=0
AFK_CHANNEL_ID=0

# --- Categories ---
SEEN_CATEGORY_ID=0
HIDDEN_CATEGORY_ID=0
WATERBOARD_CATEGORY_ID=0

# --- Birthday ---
BIRTHDAY_ANNOUNCEMENT_CHANNEL_ID=0
BIRTHDAY_REACTION_CHANNEL_ID=0
BIRTHDAY_ROLE_ID=0
BIRTHDAY_EMOJI_ID=0
BIRTHDAY_CHANNEL_ID=0

# --- MTG Autocard ---
MTG_AUTOLINK_CHANNEL_IDS=[]  # JSON array
MTG_AUTOLINK_COOLDOWN_CHANNEL_IDS=[]  # JSON array
MTG_AUTOLINK_BLOCKED_NAMES=[]  # JSON array of card names to skip
MTG_AUTOLINK_MAX_CARDS_PER_MESSAGE=5
MTG_AUTOLINK_MAX_WORD_SPAN=4

# --- Economy ---
COIN_EMOJI_ID=0

# --- TCG ---
MANA_SYMBOLS={}  # JSON dict

# --- External APIs ---
OMDB_API_KEY=
OMDB_API_URL=
BRAVE_SEARCH_API_KEY=

# --- Other ---
ENVIRONMENT=production
WEBHOOK_URL=
CHARACTER_AVATARS={}  # JSON dict
ZERONI_REACTION_EMOJI=
COMMUNITY_NOTES_REACTION_EMOJI=