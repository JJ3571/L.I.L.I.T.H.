# Discord Bot Sandbox — environment template
#
# Copy to repo-root `.env` (gitignored). Used by:
#   • Docker Compose `${VAR}` substitution for plain `docker compose …` (Compose reads this file)
#   • Optional alongside `./scripts/docker_compose_up.sh` (that script uses Doppler-injected env; a plaintext `.env` can still supply keys you keep only on disk)
#   • Local runs when combined with dotenv tooling / shell exports (optional)
#
# Populate from Doppler (`doppler secrets download --format env .env` — must be `KEY=value` lines) or by hand.
# Do not commit real secrets.

# =============================================================================
# Runtime toggles — read by main_bot.main (not server_configs/config.py)
# =============================================================================
# Tokens for truthy: 1, true, yes, on    — falsy: 0, false, no, off
# Leave blank to use the Python defaults documented below.

# Load ``main_bot.cogs.development`` after production cogs.
# Unset → ``DEVELOPMENT_COG_EXTENSIONS_ENABLED`` in main.py (currently True).
LOAD_DEVELOPMENT_COGS=

# Verbose ``[DEBUG]`` lines on stdout from selected cogs (e.g. birthday/reminder loops).
# Unset → false.
FULL_DEBUG_IN_TERMINAL=

# Verbosity for the Nextcord logger written to the **combined** runtime file (same path as ``BOT_LOG_FILE``, default ``logs/discord_bot.log``). Used by ``/logging`` when not tailing systemd journal. Values: DEBUG, INFO, WARNING, ERROR, CRITICAL. Default INFO — DEBUG floods embeds/Gateway spam.
NEXTCORD_FILE_LOG_LEVEL=

# App log subtree ``main_bot.*`` inside that same rotating file (``boot_print``, cog lines, etc.). Default INFO.
APP_LOG_LEVEL=

# When true/default, boot/cog logging still echoes to stdout (``docker compose logs``). Set false to rely on the file under ``logs/``.
APP_LOG_STDOUT_MIRROR=

# =============================================================================
# Required — core bot & database (server_configs/config.py + db pool)
# =============================================================================
DISCORD_BOT_TOKEN=
APPLICATION_ID=
GUILD_ID=
DATABASE_URL=postgresql://user:password@host:5432/database

# =============================================================================
# Deployment / Lavalink / local music HTTP
# =============================================================================
ENVIRONMENT=production

# Lavalink HTTP API (must match lavalink/application.yml ``server.password``).
# For laptop / ``python main.py``, point at localhost when Lavalink listens on the host:
LAVALINK_URI=http://127.0.0.1:2333
LAVALINK_PASSWORD=youshallnotpass

# YouTube OAuth for the **Lavalink** container (youtube-plugin). Interpolates into ``lavalink/application.yml`` and is
# forwarded in ``docker-compose.yml`` ``services.lavalink.environment``. Not read by the Python bot. After the device
# flow, copy the refresh token from Lavalink logs into secrets (treat logs as sensitive). Defaults when unset: OAuth off.
YOUTUBE_OAUTH_ENABLED=false
# YOUTUBE_OAUTH_REFRESH_TOKEN=

# Docker Compose substitution only — not read directly by Python. When unset and you use bundled
# ``docker-compose.yml``, Compose sets bot ``LAVALINK_URI=http://lavalink:2333`` automatically.
# Set only for Lavalink hosted outside Compose (wrong: ``http://127.0.0.1`` — that address is the bot container itself).
# LAVALINK_DOCKER_URI=http://other-hostname:2333

# Loopback HTTP serving ``local_audio/music`` to Lavalink (see jazz_http_server cog).
MUSIC_LOCAL_HTTP_HOST=127.0.0.1
# Optional aiohttp bind (empty ⇒ same as MUSIC_LOCAL_HTTP_HOST). Docker Compose typically needs 0.0.0.0 here while
# MUSIC_LOCAL_HTTP_HOST is the Compose service hostname Lavalink resolves (often ``bot``).
MUSIC_LOCAL_HTTP_BIND_HOST=
MUSIC_LOCAL_HTTP_PORT=8765

# JSON array of voice channel IDs where slash music / VC controls are blocked (optional).
MUSIC_VOICE_CHANNEL_DENYLIST=[]

# Optional: flat folders under ``local_audio/music/{MUSIC_FOLDER_n}`` register a /{name} slash command (Discord names: lower a-z, 0-9, hyphen, underscore; max 32 chars). Slots 1–25; empty = skip. Reserved names: ``gaming``, ``brainrot``.
# MUSIC_FOLDER_1=jazz
# ``MUSIC_n_SHUFFLE_START=true`` = random seek into each track; unset/false = play tracks from the beginning (queue order is still shuffled on start).
# MUSIC_1_SHUFFLE_START=true
# MUSIC_FOLDER_2=lofi

# =============================================================================
# Admin `.logging` cog & Brave image tuning
# =============================================================================
# Docker Compose defaults ``BOT_LOG_FILE`` to ``/app/logs/discord_bot.log`` and bind-mounts ``./logs`` → ``/app/logs`` — inspect logs on the host under ``./logs/``.
BOT_LOG_JOURNAL_UNIT=
BOT_LOG_JOURNAL_EXTRA_UNITS=
# Empty → ``<repo>/logs/discord_bot.log`` locally; absolute path overrides (e.g. VPS path outside the repo).
BOT_LOG_FILE=

# Rotation for the combined file (matches ``docker-compose.yml`` defaults).
BOT_LOG_MAX_BYTES=
BOT_LOG_BACKUP_COUNT=

BRAVE_IMAGE_SEARCH_MIN_INTERVAL=
BRAVE_TIERLIST_IMAGE_MIN_HEIGHT=
BRAVE_TIERLIST_IMAGE_MIN_WIDTH=

# =============================================================================
# Crafty Controller
# =============================================================================
CRAFTY_BASE_URL=
CRAFTY_USERNAME=
CRAFTY_PASSWORD=

# =============================================================================
# Admin & error alerts
# =============================================================================
ADMIN_USER_IDS=[]
ERROR_ALERT_USER_ID=0
ERROR_ALERT_CHANNEL_ID=0

# =============================================================================
# Channels & categories (IDs as integers / strings per config parsers)
# =============================================================================
BOT_SPAM_ID=0
VOICE_CHANNEL_IDS=[]
CREATE_FIRETEAM_CHANNEL_ID=0
WATCH_PARTY_CHANNEL_ID=0
WATCH_PARTY_EVENT_ID=0
LEAGUE_CHANNEL_ID=0
BACKUP_CHANNEL_ID=0
AFK_CHANNEL_ID=0

SEEN_CATEGORY_ID=0
HIDDEN_CATEGORY_ID=0
WATERBOARD_CATEGORY_ID=0

# =============================================================================
# Emojis & birthdays
# =============================================================================
HEADS_EMOJI_ID=0
TAILS_EMOJI_ID=0
COIN_EMOJI_ID=0

BIRTHDAY_ANNOUNCEMENT_CHANNEL_ID=0
BIRTHDAY_REACTION_CHANNEL_ID=0
BIRTHDAY_ROLE_ID=0
BIRTHDAY_EMOJI_ID=0
BIRTHDAY_CHANNEL_ID=0

# =============================================================================
# MTG autocard / TCG / Say
# =============================================================================
MTG_AUTOLINK_CHANNEL_IDS=[]
MTG_AUTOLINK_COOLDOWN_CHANNEL_IDS=[]
MTG_AUTOLINK_BLOCKED_NAMES=[]
MTG_AUTOLINK_MAX_CARDS_PER_MESSAGE=5
MTG_AUTOLINK_MAX_WORD_SPAN=4

MANA_SYMBOLS={}

# =============================================================================
# External APIs & Gemini
# =============================================================================
GEMINI_API_KEY=
OMDB_API_KEY=
OMDB_API_URL=
BRAVE_SEARCH_API_KEY=

# =============================================================================
# Say / webhook config (JSON dict for CHARACTER_AVATARS)
# =============================================================================
WEBHOOK_URL=
CHARACTER_AVATARS={}
ZERONI_REACTION_EMOJI=
COMMUNITY_NOTES_REACTION_EMOJI=
